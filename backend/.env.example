# App
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-min-32-chars-here
PAPER_TRADING=true

# Database (Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/btc_options

# Redis (Docker)
REDIS_URL=redis://localhost:6379/0

# Exchange API Keys (optional for paper trading)
DERIBIT_API_KEY=
DERIBIT_API_SECRET=
DERIBIT_TESTNET=true

BINANCE_API_KEY=
BINANCE_API_SECRET=

# Risk Limits
MAX_POSITION_SIZE_USD=10000
MAX_DELTA_EXPOSURE=1.0
MAX_VEGA_EXPOSURE=5000
MAX_DAILY_LOSS_USD=1000
MAX_PORTFOLIO_LEVERAGE=3.0

# Pricing
RISK_FREE_RATE=0.05
PRICING_MODEL=black_scholes
